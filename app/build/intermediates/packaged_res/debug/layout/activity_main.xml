<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/water_deep">

    <com.monkeyswim.game.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/hud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/hud_bg"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/scoreLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/hud_text"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Score 0" />

        <TextView
            android:id="@+id/levelLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/hud_text"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Level 1" />

        <TextView
            android:id="@+id/livesLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/hud_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="end"
            tools:text="Lives 3" />

        <Button
            android:id="@+id/pauseButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="6dp"
            android:layout_marginStart="12dp"
            android:text="@string/pause_action"
            android:textColor="@color/button_text"
            android:backgroundTint="@color/button_bg"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/gameOverOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/splash_bg"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:id="@+id/gameOverTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/game_over"
                android:textColor="@color/hud_text"
                android:textSize="42sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp" />

            <Button
                android:id="@+id/restartButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="220dp"
                android:text="@string/restart"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_bg"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/watchAdButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="220dp"
                android:text="@string/watch_ad_for_lives"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_bg" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/centerBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="@color/power_pellet"
        android:textSize="42sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="Ready!" />

</FrameLayout>

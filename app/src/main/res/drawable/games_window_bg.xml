<?xml version="1.0" encoding="utf-8"?>
<!-- Opaque rounded panel with a gold border so the "More Games" overlay reads
     as a floating window over the dimmed game, rather than a full-screen wash. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#0E3A56" />
    <corners android:radius="20dp" />
    <stroke
        android:width="2dp"
        android:color="@color/power_pellet" />
</shape>

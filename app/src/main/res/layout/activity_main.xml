<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/water_deep">

    <com.monkeyswim.game.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/hud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/hudBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@color/hud_bg"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/scoreLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/hud_text"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Score 0" />

            <TextView
                android:id="@+id/levelLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/hud_text"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Level 1" />

            <TextView
                android:id="@+id/livesLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/hud_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="end"
                tools:text="Lives 3" />

            <Button
                android:id="@+id/baitButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:text="@string/bait_button"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_bg"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="🐟 1" />

            <Button
                android:id="@+id/soundButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:text="@string/sound_on"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/button_bg"
                android:textSize="16sp" />

            <Button
                android:id="@+id/helpButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:text="@string/help_button"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_bg"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Debug-only level selector. Visibility is set programmatically in
             MainActivity based on BuildConfig.DEBUG, so it never appears in
             release builds. -->
        <LinearLayout
            android:id="@+id/debugBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="@color/hud_bg"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_level_selector_label"
                android:textColor="@color/hud_text"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <Spinner
                android:id="@+id/debugLevelSpinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/button_bg" />

            <Button
                android:id="@+id/debugFruitButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:text="@string/debug_fruit_button"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_bg"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/gameOverOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/splash_bg"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:id="@+id/gameOverTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/game_over"
                android:textColor="@color/hud_text"
                android:textSize="42sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp" />

            <Button
                android:id="@+id/restartButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="220dp"
                android:text="@string/restart"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_bg"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/watchAdButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="220dp"
                android:text="@string/watch_ad_for_lives"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_bg" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/centerBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="@color/power_pellet"
        android:textSize="42sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="Ready!" />

    <FrameLayout
        android:id="@+id/allLevelsCompleteOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/splash_bg"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/all_levels_complete_title"
                android:textColor="@color/power_pellet"
                android:textSize="40sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/all_levels_complete_subtitle"
                android:textColor="@color/hud_text"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            <Button
                android:id="@+id/continueChallengeButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="240dp"
                android:text="@string/continue_challenge"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_bg"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/restartFromCompleteButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="240dp"
                android:text="@string/restart_from_start"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_bg"
                android:textSize="18sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Mechanic intro overlay — shown the first time the player encounters
         currents (L5) or the tide cycle (L15). Title and body are set
         programmatically. Dismissed by "Got it!" which marks the mechanic
         as seen and resumes the game. -->
    <FrameLayout
        android:id="@+id/mechanicIntroOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/splash_bg"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:paddingVertical="32dp">

            <TextView
                android:id="@+id/mechanicIntroTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/power_pellet"
                android:textSize="40sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"
                tools:text="Currents!" />

            <TextView
                android:id="@+id/mechanicIntroBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/hud_text"
                android:textSize="16sp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="32dp"
                tools:text="Description of the mechanic appears here." />

            <Button
                android:id="@+id/mechanicIntroDismiss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="200dp"
                android:text="@string/intro_got_it"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_bg"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/splashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/splash_bg"
        android:clickable="true"
        android:focusable="true">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingHorizontal="32dp"
                android:paddingTop="64dp"
                android:paddingBottom="32dp">

                <TextView
                    android:id="@+id/splashTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/power_pellet"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/splashCopyright"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/copyright"
                    android:textColor="@color/hud_text"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="32dp" />

                <TextView
                    android:id="@+id/splashInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/splash_instructions"
                    android:textColor="@color/pellet"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginBottom="40dp" />

                <TextView
                    android:id="@+id/splashDifficultyLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/difficulty_label"
                    android:textColor="@color/pellet"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <RadioGroup
                    android:id="@+id/splashDifficultyGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="40dp">

                    <RadioButton
                        android:id="@+id/difficultyEasy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/difficulty_easy"
                        android:textColor="@color/hud_text"
                        android:buttonTint="@color/power_pellet"
                        android:textSize="18sp"
                        android:padding="6dp" />

                    <RadioButton
                        android:id="@+id/difficultyMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/difficulty_medium"
                        android:textColor="@color/hud_text"
                        android:buttonTint="@color/power_pellet"
                        android:textSize="18sp"
                        android:padding="6dp"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/difficultyHard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/difficulty_hard"
                        android:textColor="@color/hud_text"
                        android:buttonTint="@color/power_pellet"
                        android:textSize="18sp"
                        android:padding="6dp" />
                </RadioGroup>

                <Button
                    android:id="@+id/splashStartButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="220dp"
                    android:text="@string/start_game"
                    android:textColor="@color/button_text"
                    android:backgroundTint="@color/button_bg"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="32dp" />

                <TextView
                    android:id="@+id/splashPrivacyLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/privacy_policy"
                    android:textColor="@color/power_pellet"
                    android:textSize="14sp"
                    android:padding="12dp" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/helpOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/splash_bg"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingHorizontal="32dp"
                android:paddingTop="48dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/help_title"
                    android:textColor="@color/power_pellet"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/splash_instructions"
                    android:textColor="@color/pellet"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_pause_hint"
                    android:textColor="@color/hud_text"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="32dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/help_powerups_label"
                    android:textColor="@color/pellet"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_banana"
                    android:textColor="@color/hud_text"
                    android:textSize="14sp"
                    android:gravity="start"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_lightning"
                    android:textColor="@color/hud_text"
                    android:textSize="14sp"
                    android:gravity="start"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_blackhole"
                    android:textColor="@color/hud_text"
                    android:textSize="14sp"
                    android:gravity="start"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_shark"
                    android:textColor="@color/hud_text"
                    android:textSize="14sp"
                    android:gravity="start"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_turtle"
                    android:textColor="@color/hud_text"
                    android:textSize="14sp"
                    android:gravity="start"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_heart"
                    android:textColor="@color/hud_text"
                    android:textSize="14sp"
                    android:gravity="start"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/help_bait"
                    android:textColor="@color/hud_text"
                    android:textSize="14sp"
                    android:gravity="start"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="32dp" />

                <Button
                    android:id="@+id/helpCloseButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="180dp"
                    android:text="@string/help_close"
                    android:textColor="@color/button_text"
                    android:backgroundTint="@color/button_bg"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

</FrameLayout>
